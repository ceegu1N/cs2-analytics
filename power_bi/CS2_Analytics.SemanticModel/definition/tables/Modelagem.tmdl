	partition Modelagem = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(DataRoot & "\fact_model_match.csv"), [Delimiter=";", Columns=45, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Types = Table.TransformColumnTypes(Headers, {{"model_match_id", Int64.Type}, {"match_date_key", Int64.Type}, {"season_label", type text}, {"season_usage", type text}, {"team_id", Int64.Type}, {"opponent_team_id", Int64.Type}, {"win_target", Int64.Type}, {"context_is_lan", type number}, {"diff_elo_pre_match", type number}}, "pt-BR")
				in
					Types

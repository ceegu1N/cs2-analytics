	column 'Contexto LAN'
		dataType: double
		lineageTag: b6eedec4-e3b4-4e34-a002-7df2f4b403f3
		summarizeBy: sum
		sourceColumn: context_is_lan

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Diferenca ELO'
		dataType: double
		formatString: #,##0.0
		lineageTag: dd195532-1287-49e0-bada-886eb099874b
		summarizeBy: sum
		sourceColumn: diff_elo_pre_match

		annotation SummarizationSetBy = Automatic

	column Ambiente = IF(Modelagem[Contexto LAN] = 1, "LAN", "ONLINE")
		dataType: string
		lineageTag: d211350e-9c27-4b86-9f1e-cb1b55a4c091
		summarizeBy: none

	column 'Diferenca absoluta ELO' = ABS(Modelagem[Diferenca ELO])
		dataType: decimal
		formatString: #,##0.0
		lineageTag: 241d64ad-17ee-4481-8e39-34ee36855600
		summarizeBy: none

	column 'Ordem faixa ELO' =
			SWITCH(
				TRUE(),
				Modelagem[Diferenca absoluta ELO] < 50, 1,
				Modelagem[Diferenca absoluta ELO] < 100, 2,
				Modelagem[Diferenca absoluta ELO] < 200, 3,
				4
			)
		dataType: int64
		isHidden
		lineageTag: ee37a404-77ae-4a87-abf8-36b05177a0c8
		summarizeBy: none

	column 'Faixa ELO' =
			SWITCH(
				Modelagem[Ordem faixa ELO],
				1, "0-49",
				2, "50-99",
				3, "100-199",
				"200+"
			)
		dataType: string
		lineageTag: 04ba987d-127b-4c5a-a396-74b46e3872ea
		summarizeBy: none
		sortByColumn: 'Ordem faixa ELO'

	column 'Maior ELO venceu' =
			IF(
				Modelagem[Diferenca ELO] = 0,
				BLANK(),
				IF(
					(Modelagem[Diferenca ELO] > 0 && Modelagem[Resultado] = 1)
						|| (Modelagem[Diferenca ELO] < 0 && Modelagem[Resultado] = 0),
					1,
					0
				)
			)
		dataType: int64
		lineageTag: c25f7e3e-2cf3-4bbb-931f-65578b78aee6
		summarizeBy: average


	partition PartidasEquipe = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(DataRoot & "\fact_team_match.csv"), [Delimiter=";", Columns=13, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),

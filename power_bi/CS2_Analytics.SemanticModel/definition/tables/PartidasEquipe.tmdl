					Types = Table.TransformColumnTypes(Headers, {{"perspective_id", Int64.Type}, {"match_id", Int64.Type}, {"match_date_key", Int64.Type}, {"season_label", type text}, {"season_usage", type text}, {"team_id", Int64.Type}, {"opponent_team_id", Int64.Type}, {"win", Int64.Type}, {"best_of", type text}, {"lan_online", type text}}, "pt-BR")
				in
					Types
